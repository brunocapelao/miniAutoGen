name: web_search
description: Search the web for relevant information.

input_schema:
  type: object
  properties:
    query:
      type: string
      description: The search query
    top_k:
      type: integer
      minimum: 1
      maximum: 20
      default: 5
  required:
    - query

execution:
  kind: python
  target: miniautogen.tools.web_search:execute

policy:
  approval: none
  timeout_seconds: 30
